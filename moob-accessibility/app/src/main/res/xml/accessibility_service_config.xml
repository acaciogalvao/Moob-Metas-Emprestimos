<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuração do AccessibilityService do MoobAccessibility.

    accessibilityEventTypes: monitora mudanças de janela e de conteúdo
    accessibilityFeedbackType: TYPE_GENERIC (não exibe feedback de voz/haptic próprio)
    canRetrieveWindowContent: true → permite ler o conteúdo dos nós de UI (textos)
    notificationTimeout: 100ms — processa eventos rapidamente
    packageNames: monitora apenas Uber Driver e 99 Driver (evita processar todo o sistema)
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="100"
    android:description="@string/accessibility_service_description"
    android:packageNames="com.ubercab.driver,com.taxis99,br.com.taxis99.motorista,com.taxis99.driver" />
